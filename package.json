    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/config": "^0.5.2",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.10"
